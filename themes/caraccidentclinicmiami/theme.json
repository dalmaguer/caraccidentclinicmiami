{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "calc(min(100vw, 1200px) - 4rem)",
			"wideSize": "1920px"
		},
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"palette": [
				{
					"name": "Primary",
					"slug": "primary",
					"color": "#0C2D48"
				},
				{
					"name": "Primary Dark",
					"slug": "primary-dark",
					"color": "#111827"
				},
				{
					"name": "Primary Blue",
					"slug": "primary-blue",
					"color": "#2563EB"
				},
				{
					"name": "Secondary Teal",
					"slug": "secondary-teal",
					"color": "#5BB5A2"
				},
				{
					"name": "Secondary Light",
					"slug": "secondary-light",
					"color": "#B2C8D5"
				},
				{
					"name": "White",
					"slug": "white",
					"color": "#FFFFFF"
				},
				{
					"name": "Light Gray",
					"slug": "light-gray",
					"color": "#F3F4F6"
				},
				{
					"name": "Gray",
					"slug": "gray",
					"color": "#6B7280"
				},
				{
					"name": "Dark",
					"slug": "dark",
					"color": "#1A1A1A"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"name": "Barlow",
					"slug": "barlow",
					"fontFamily": "'Barlow', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Barlow",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": ["https://fonts.gstatic.com/s/barlow/v12/7cHpv4kjgoGqM7E_DMs5.woff2"]
						},
						{
							"fontFamily": "Barlow",
							"fontWeight": "600",
							"fontStyle": "normal",
							"src": ["https://fonts.gstatic.com/s/barlow/v12/7cHqv4kjgoGqM7E3t-4s51os.woff2"]
						},
						{
							"fontFamily": "Barlow",
							"fontWeight": "700",
							"fontStyle": "normal",
							"src": ["https://fonts.gstatic.com/s/barlow/v12/7cHqv4kjgoGqM7E3_-8s51os.woff2"]
						},
						{
							"fontFamily": "Barlow",
							"fontWeight": "800",
							"fontStyle": "normal",
							"src": ["https://fonts.gstatic.com/s/barlow/v12/7cHqv4kjgoGqM7E30-ws51os.woff2"]
						}
					]
				},
				{
					"name": "Open Sans",
					"slug": "open-sans",
					"fontFamily": "'Open Sans', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Open Sans",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": ["https://fonts.gstatic.com/s/opensans/v40/memSYaGs76AUhyKypu0W.woff2"]
						},
						{
							"fontFamily": "Open Sans",
							"fontWeight": "600",
							"fontStyle": "normal",
							"src": ["https://fonts.gstatic.com/s/opensans/v40/memSYaGs76AUhyKypu0W.woff2"]
						},
						{
							"fontFamily": "Open Sans",
							"fontWeight": "700",
							"fontStyle": "normal",
							"src": ["https://fonts.gstatic.com/s/opensans/v40/memSYaGs76AUhyKypu0W.woff2"]
						}
					]
				}
			],
			"fontSizes": [
				{ "name": "Small", "slug": "small", "size": "0.875rem" },
				{ "name": "Base", "slug": "base", "size": "1rem" },
				{ "name": "Medium", "slug": "medium", "size": "1.125rem" },
				{ "name": "Large", "slug": "large", "size": "1.5rem" },
				{ "name": "X-Large", "slug": "x-large", "size": "2rem" },
				{ "name": "2X-Large", "slug": "2x-large", "size": "2.5rem" },
				{ "name": "3X-Large", "slug": "3x-large", "size": "3rem" },
				{
					"name": "Huge",
					"slug": "huge",
					"size": "clamp(2.5rem, 5vw, 3.75rem)",
					"fluid": { "min": "2.5rem", "max": "3.75rem" }
				}
			]
		},
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true,
			"units": ["%", "px", "em", "rem", "vh", "vw"],
			"spacingSizes": [
				{ "name": "2XS", "slug": "10", "size": "0.25rem" },
				{ "name": "XS", "slug": "20", "size": "0.5rem" },
				{ "name": "S", "slug": "30", "size": "0.75rem" },
				{ "name": "M", "slug": "40", "size": "1rem" },
				{ "name": "L", "slug": "50", "size": "1.5rem" },
				{ "name": "XL", "slug": "60", "size": "2rem" },
				{ "name": "2XL", "slug": "70", "size": "3rem" },
				{ "name": "3XL", "slug": "80", "size": "4rem" },
				{ "name": "4XL", "slug": "90", "size": "5rem" },
				{ "name": "5XL", "slug": "100", "size": "6rem" }
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--open-sans)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.6"
		},
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--dark)"
		},
		"spacing": {
			"blockGap": "0",
			"padding": {
				"top": "0",
				"right": "0",
				"bottom": "0",
				"left": "0"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--barlow)",
					"fontWeight": "700",
					"lineHeight": "1.15"
				},
				"color": {
					"text": "var(--wp--preset--color--primary-dark)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--huge)",
					"fontWeight": "800"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "600"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-dark)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary-dark)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--open-sans)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--base)"
				},
				"border": {
					"radius": "6px"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"bottom": "0.75rem",
						"left": "1.75rem",
						"right": "1.75rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--dark)"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--barlow)",
					"fontWeight": "700",
					"fontSize": "var(--wp--preset--font-size--large)"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--primary-dark)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--open-sans)",
					"fontSize": "var(--wp--preset--font-size--base)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
